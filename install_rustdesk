#!/bin/bash

# Ensure script is run as root
if [ "$EUID" -ne 0 ]; then
  echo "Please run as root (e.g., using sudo)."
  exit 1
fi

echo "Fetching the latest RustDesk release tag..."
# Fetch the latest release tag directly from the RustDesk GitHub API
RD_VERSION=$(curl -s https://api.github.com/repos/rustdesk/rustdesk/releases/latest | grep tag_name | cut -d '"' -f 4 | sed 's/v//')

if [ -z "$RD_VERSION" ]; then
  echo "Failed to fetch the latest version tag. Please check your internet connection."
  exit 1
fi

echo "Installing RustDesk version: v$RD_VERSION"

# Set architecture variable (only 64-bit is officially supported for modern releases)
ARCH="x86_64"
DEB_FILE="rustdesk-${RD_VERSION}-${ARCH}.deb"

# Download the latest .deb package
echo "Downloading https://github.com/rustdesk/rustdesk/releases/download/${RD_VERSION}/${DEB_FILE}..."
wget -qO "$DEB_FILE" "https://github.com/rustdesk/rustdesk/releases/download/${RD_VERSION}/${DEB_FILE}"

# Check if the download succeeded
if [ ! -f "$DEB_FILE" ]; then
  echo "Download failed. Please manually check the RustDesk GitHub releases page."
  exit 1
fi

# Install the downloaded deb package and fix missing dependencies
echo "Installing package and resolving dependencies..."
apt-get update -y
apt-get install -fy "./$DEB_FILE"

# Clean up the installer file
echo "Cleaning up..."
rm -f "$DEB_FILE"

echo "Installation complete! You can now launch RustDesk from your applications menu."
